# ─── EmailJS (contact form) ───
# Sign up at emailjs.com, create a service + template, then:
# 1. Copy this file to .env.local
# 2. Fill in the three values below
# 3. Restart the dev server
#
# Template variables the form sends (wire these in your EmailJS template):
#   {{from_name}}  {{from_email}}  {{company}}  {{project_type}}
#   {{budget}}     {{message}}     {{to_email}}
#
# When these env vars are absent, the contact form falls back to a
# mailto: handoff to founder@voilacode.com — nothing breaks.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
